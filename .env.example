# Copy to `.env` and adjust values. Nuxt loads `.env` automatically in dev/build.
# -----------------------------------------------------------------------------
# Public (exposed to client + server via runtimeConfig.public)
# -----------------------------------------------------------------------------

# Backend API base URL (no trailing slash recommended; must match your API version path)
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Brand / app name (used in document title in nuxt.config and app.config)
NUXT_PUBLIC_APP_NAME=KaribCon

# Display name under runtimeConfig.public (see nuxt.config.ts)
NUXT_APP_NAME=KaribCon

# Role UUIDs from your backend for POST /users/{id}/roles/{role_id}
NUXT_PUBLIC_ROLE_ID_ADMIN=
NUXT_PUBLIC_ROLE_ID_ORGANIZER=
NUXT_PUBLIC_ROLE_ID_ATTENDEE=

# -----------------------------------------------------------------------------
# Server-only (not exposed to the browser)
# -----------------------------------------------------------------------------

# JWT signing/verification secret for server-side auth helpers (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
